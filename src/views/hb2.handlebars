<!DOCTYPE html>
<html lang="pt-br">
<head>
  <meta charset="UTF-8">
  <title>HB2 - If</title>
</head>
<body>
  {{#if isLoggedIn}}
    <h1>Bem-vindo de volta!</h1>
    <p>Você já pode jogar o SpitSnake.</p>
  {{else}}
    <h1>Você não está logado</h1>
    <p>Faça login para acessar o jogo.</p>
  {{/if}}
</body>
</html>